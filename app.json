{
  "expo": {
    "name": "Gunpla",
    "slug": "gunpla-paint-colour",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gunpla.paintcolour"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.gunpla.paintcolour"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Gunpla needs access to your photos to identify paint colours from images.",
          "cameraPermission": "Gunpla needs camera access to scan paint pots and capture reference colours."
        }
      ]
    ],
    "scheme": "gunpla",
    "experiments": {
      "typedRoutes": true
    }
  }
}
